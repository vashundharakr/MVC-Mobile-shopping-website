@{
    ViewData["Title"] = "Register";
}

<!-- Registration Page -->
<div class="container w-50 border p-3">
    <h3 class="text-center">Register</h3>
    <form id="registerForm" method="post">
        <div class="form-group">
            <label for="usernameRegister" class="fw-bold my-2">User name</label>
            <input type="text" class="form-control" id="usernameRegister" required />
            <small class="text-danger" id="usernameError"></small>
            <small class="text-muted">Username must be at least 3 characters.</small>
        </div>

        <div class="form-group">
            <label for="passwordRegister" class="fw-bold my-2">Password</label>
            <input type="password" class="form-control" id="passwordRegister" required />
            <small class="text-danger" id="passwordError"></small>
            <small class="text-muted">
                Password must be at least 8 characters, include one uppercase letter, one number, and one special character.
            </small>
        </div>

        <div class="form-group">
            <label for="confirmPassword" class="fw-bold my-2">Confirm Password</label>
            <input type="password" class="form-control" id="confirmPassword" required />
            <small class="text-danger" id="confirmPasswordError"></small>
            <small class="text-muted">Retype password for confirmation</small>
        </div>

        <div class="form-group">
            <label for="inputEmail4" class="fw-bold my-2">Email</label>
            <input type="email" class="form-control" id="inputEmail4" placeholder="xyz@gmail.com" required />
            <small class="text-danger" id="emailError"></small>
        </div>

        <div class="form-group">
            <label for="phoneNumber" class="fw-bold my-2">Phone Number</label>
            <input type="text" class="form-control" id="phoneNumber" required />
            <small class="text-danger" id="phoneError"></small>
            <small class="text-muted">Enter a valid phone number (e.g., 9876543210)</small>
        </div>

        <div class="form-group">
            <label for="inputAddress" class="fw-bold my-2">Address</label>
            <input type="text" class="form-control" id="inputAddress" required />
            <small class="text-danger" id="addressError"></small>
        </div>

        <button type="submit" class="btn btn-dark w-100 my-3">Register</button>
        <h6 class="text-end my-3">Already a user? <a class="text-primary" href="/Login">Login</a></h6>
    </form>
</div>

<script src="./js/apiService.js"></script>
<script>
    function validateUsername() {
        const username = document.getElementById("usernameRegister").value.trim();
        const error = document.getElementById("usernameError");
        if (username.length < 3) {
            error.innerText = "Invalid Username.";
            return false;
        }
        error.innerText = "";
        return true;
    }

    function validatePassword() {
        const password = document.getElementById("passwordRegister").value;
        const error = document.getElementById("passwordError");
        const regex = /^(?=.*[A-Z])(?=.*\d)(?=.*[$!%*?&])[A-Za-z\d$!%*?&]{8,}$/;
        if (!regex.test(password)) {
            error.innerText = "Invalid Password.";
            return false;
        }
        error.innerText = "";
        return true;
    }

    function validateConfirmPassword() {
        const password = document.getElementById("passwordRegister").value;
        const confirmPassword = document.getElementById("confirmPassword").value;
        const error = document.getElementById("confirmPasswordError");
        if (password !== confirmPassword) {
            error.innerText = "Passwords do not match.";
            return false;
        }
        error.innerText = "";
        return true;
    }

    function validatePhone() {
        const phone = document.getElementById("phoneNumber").value;
        const error = document.getElementById("phoneError");
        const regex = /^[7-9]{1}[0-9]{9}$/;
        if (!regex.test(phone)) {
            error.innerText = "Enter a valid phone number (e.g., 9876543210).";
            return false;
        }
        error.innerText = "";
        return true;
    }

    function validateAddress() {
        const address = document.getElementById("inputAddress").value.trim();
        const error = document.getElementById("addressError");
        if (address.length < 5) {
            error.innerText = "Address must be at least 5 characters.";
            return false;
        }
        error.innerText = "";
        return true;
    }

    // Attach validation on input event to remove errors dynamically
    document.getElementById("usernameRegister").addEventListener("input", validateUsername);
    document.getElementById("passwordRegister").addEventListener("input", validatePassword);
    document.getElementById("confirmPassword").addEventListener("input", validateConfirmPassword);
    document.getElementById("phoneNumber").addEventListener("input", validatePhone);
    document.getElementById("inputAddress").addEventListener("input", validateAddress);

    // Handle Form Submission
    document.getElementById('registerForm').addEventListener('submit', async function (e) {
        e.preventDefault();

        // Run all validations
        const isValid = validateUsername() && validatePassword() && validateConfirmPassword() &&
                         validatePhone() && validateAddress();

        if (!isValid) {
            return; // Stop submission if any validation fails
        }

        const registerData = {
            username: document.getElementById("usernameRegister").value,
            password: document.getElementById("passwordRegister").value,
            email: document.getElementById("inputEmail4").value,
            phoneNumber: document.getElementById("phoneNumber").value,
            address: document.getElementById("inputAddress").value
        };

        try {
            // Send POST request to the API
            const response = await apiService.post("RegisterUser", registerData);

            // Handle API response
            if (response.message) {
                alert('Registered Successfully!');
                window.location.href = '/Login'; // Redirect to login
            } else {
                alert(response.message || 'An error occurred during registration.');
            }
        } catch (error) {
            console.error('Error in Register:', error);
            alert(error.message || 'Failed to Register. Please try again later.');
        }
    });
</script>
