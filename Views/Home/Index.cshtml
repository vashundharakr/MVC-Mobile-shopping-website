@{
    ViewData["Title"] = "MobileStockManagement";
}

<div class="container text-center my-4">
    <div class="card shadow-sm p-4 bg-light">
        <h2 class="text-uppercase fw-bold" style="color: grey; font-size: 2.5rem; text-shadow: 2px 2px 4px rgba(0,0,0,0.2);">Aspire Mobileshop</h2>
        <p class="text-muted">Welcome to Aspire Mobileshop! Find the best mobile deals here.</p>
        @* @{Html.RenderPartial("~/Views/_Partialview.cshtml");} *@
    </div>
</div>

<div class="container">
    <div class="row mb-3">
        <div class="col-md-6 mx-auto">
            <input type="text" id="searchBox" class="form-control" placeholder="⌕ Search Mobile..." onkeyup="filterMobiles()">
        </div>
    </div>

    <div id="mobileCarousel" class="carousel slide mb-4" data-bs-ride="carousel">
        <div class="carousel-inner" id="carouselItems"></div>
        <button class="carousel-control-prev" type="button" data-bs-target="#mobileCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#mobileCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
        </button>
    </div>

    <div class="row" id="mobileCardsRow"></div>
</div>

<script src="/js/apiService.js"></script>
<script>
    let allProducts = [];

    const loadMobileCards = async () => {
        try {
            allProducts = await apiService.get('Purchase');
            renderMobiles(allProducts);
            renderCarousel(allProducts);
        } catch (error) {
            console.error('Error loading mobiles:', error);
            alert('Failed to load mobile stock.');
        }
    };

    const renderMobiles = (products) => {
        const row = document.getElementById('mobileCardsRow');
        row.innerHTML = products.map(product => `
            <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                <div class="card shadow-sm text-center h-100">
                    <img src="${product.mobileImage}" class="card-img-top p-3" style="height: 200px; object-fit: contain;" alt="${product.mobileName}">
                    <div class="card-body">
                        <h6 class="card-title">${product.mobileName}</h6>
                        <p class="text-danger fw-bold">₹${product.price}</p>
                       
                        <button class="btn btn-outline-primary w-100" onclick="window.location.href='/Purchase/Display/${product.mobileName}'">
                            <i class="fa fa-eye me-2"></i>View Details
                        </button>
                    </div>
                </div>
            </div>`).join('');
    };

    const renderCarousel = (products) => {
        const carousel = document.getElementById('carouselItems');
        carousel.innerHTML = products.slice(0, 5).map((product, index) => `
            <div class="carousel-item ${index === 0 ? 'active' : ''}">
                <img src="${product.mobileImage}" class="d-block mx-auto" style="height: 300px; object-fit: contain;">
                <div class="carousel-caption bg-dark bg-opacity-50 rounded p-2">
                    <h5>${product.mobileName}</h5>
                    <p>₹${product.price}</p>
                </div>
            </div>`).join('');
    };

    const filterMobiles = () => {
        const query = document.getElementById('searchBox').value.toLowerCase();
        const filteredProducts = allProducts.filter(product => product.mobileName.toLowerCase().includes(query));
        renderMobiles(filteredProducts);
    };

    document.addEventListener('DOMContentLoaded', loadMobileCards);
</script>
