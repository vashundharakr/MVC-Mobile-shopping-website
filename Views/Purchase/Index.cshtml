@{
    ViewData["Title"] = "MobileStockManagement";
}

<h1 class="text-center my-4">Mobile Stock Management Application</h1>

<div class="container">
    <!-- Add Purchase Button -->
    <div class="text-end mb-4">
    </div>

    <!-- Mobile Stock Table -->
    <table id="PurchaseTable" class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Mobile Name</th>
                <th>Price</th>
                <th>Availability</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="PurchaseTableBody">
            <!-- Dynamic data will be inserted here -->
        </tbody>
    </table>
    <div class="text-center">
        <a href="/AdminHandler" class="btn btn-secondary btn-block mt-3">Go Back</a>
    </div>
</div>

<!-- Edit Mobile Modal -->
<div class="modal fade" id="editMobileModal" tabindex="-1" aria-labelledby="editMobileModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editMobileModalLabel">Edit Mobile Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="editMobileForm">
                    <div class="mb-3">
                        <label for="mobileName" class="form-label">Mobile Name</label>
                        <input type="text" class="form-control" id="mobileName" disabled>
                    </div>
                    <div class="mb-3">
                        <label for="price" class="form-label">Price</label>
                        <input type="number" class="form-control" id="price">
                    </div>
                    <div class="mb-3">
                        <label for="quantity" class="form-label">Quantity</label>
                        <input type="number" class="form-control" id="quantity">
                    </div>
                    <button type="button" class="btn btn-primary" onclick="saveUpdatedMobile()">Save Changes</button>
                    <button type="button" class="btn btn-danger mt-2" onclick="deleteMobile()">Delete Mobile</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Include the external Application service script -->
<script src="/js/apiService.js"></script>

<!-- Script to handle the population of the table and delete functionality -->
<script>
    // Function to load purchases and populate the table
    function loadPurchase() {
        apiService.get('Purchase')
            .then(purchases => {
                const tableBody = document.getElementById('PurchaseTableBody');
                tableBody.innerHTML = ''; // Clear the table body before adding new rows

                purchases.forEach(product => {
                    const rows = `
                        <tr>
                            <td>${product.mobileName}</td>
                            <td>${product.price}</td>
                            <td>${product.quantity}</td>
                            <td>
                                <button onclick="UpdateMobile('${product.mobileName}', ${product.price}, ${product.quantity})" class="btn btn-primary px-5" ><i class="fa fa-edit me-3" aria-hidden="true"></i>Edit</button>
                                <button onclick="confirmDeleteMobile('${product.mobileName}')" class="btn btn-danger px-5 ms-2"><i class="fa fa-trash me-3" aria-hidden="true"></i>Delete</button>
                            </td>
                        </tr>`;
                    tableBody.innerHTML += rows;
                });
            })
            .catch(error => {
                console.error('Error loading mobile: ', error);
                alert('Try again...');
            });
    }

    // Function to fetch mobile details and open the edit modal
    function UpdateMobile(mobileName, price, quantity) {
        // Set the current values in the modal
        document.getElementById('mobileName').value = mobileName;
        document.getElementById('price').value = price;
        document.getElementById('quantity').value = quantity;

        // Show the edit modal
        var myModal = new bootstrap.Modal(document.getElementById('editMobileModal'), {});
        myModal.show();
    }

    // Function to save the updated mobile details (with query params)
    async function saveUpdatedMobile() {
        const mobileName = document.getElementById('mobileName').value;
        const price = document.getElementById('price').value;
        const quantity = document.getElementById('quantity').value;

        // Prepare query parameters
        const queryParams = new URLSearchParams({
            mobileName: mobileName,
            newPrice: price,
            newStock: quantity
        });

        try {
            // Send the updated data to the server using GET with query params
            const response = await apiService.put(`Purchase/Mobile/Update?${queryParams.toString()}`);

            console.log(response);
            alert(`Mobile updated successfully!`);

            // Close the modal
            var myModal = bootstrap.Modal.getInstance(document.getElementById('editMobileModal'));
            myModal.hide();

            // Reload the purchase table to reflect the changes
            loadPurchase();
        } catch (error) {
            console.error('Error updating mobile:', error);
            alert('Failed to update mobile details. Try again.');
        }
    }

    // Function to confirm the deletion of a mobile
    function confirmDeleteMobile(mobileName) {
        if (confirm(`Are you sure you want to delete the mobile: ${mobileName}?`)) {
            deleteMobile(mobileName);
        }
    }

    // Function to delete the mobile by name
    async function deleteMobile(mobileName) {
        try {
            // Send the DELETE request to the server
            const response = await apiService.delete(`Purchase/remove/${mobileName}`);

            console.log(response);
            alert(`Mobile deleted successfully!`);

            // Reload the purchase table to reflect the changes
            loadPurchase();
        } catch (error) {
            console.error('Error deleting mobile:', error);
            alert('Failed to delete mobile. Try again.');
        }
    }

    // Load the purchase data when the page is loaded
    document.addEventListener('DOMContentLoaded', function () {
        loadPurchase();
    });
</script>

<!-- Bootstrap JS (for any potential Bootstrap features like modal or tooltips) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
