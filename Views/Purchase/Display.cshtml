@{
    ViewData["Title"] = "Mobile Slideshow with Names and Images";
}

<div class="container mt-5">
    <div class="row d-flex align-items-center">
        <!-- Left: Slideshow -->
        <div class="col-md-6 d-flex justify-content-center">
            <div id="mobileSlideshow" class="carousel slide shadow rounded w-50" data-bs-ride="carousel">
                <div class="carousel-indicators" id="carouselIndicators"></div>
                <div class="carousel-inner" id="carouselInner"></div>

                <!-- Controls -->
                <button class="carousel-control-prev" type="button" data-bs-target="#mobileSlideshow"
                    data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#mobileSlideshow"
                    data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>

        <!-- Right: Description Box -->
        <div class="col-md-6">
            <div class="row mb-4">
                <div class="col-md-6 text-center">
                    <button id="buyNowBtn" class="btn btn-primary btn-lg w-75">Buy Now</button>
                </div>
                <div class="col-md-6 text-center">
                    <a href="/Purchase/Views" class="btn btn-secondary btn-lg w-75">Go Back</a>
                </div>
            </div>
            <div class="card shadow-lg p-3 bg-white rounded">
                <div class="card-body">
                    <h4 class="card-title text-primary">Mobile Specifications</h4>
                    <h6 class="text-muted">Brand: <span id="mobileBrand">N/A</span></h6>
                    <hr>
                    <p class="card-text" id="mobileDescription">This mobile features high-end performance with excellent
                        battery life and camera quality.</p>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item"><strong>Price:</strong> <span id="mobilePrice">$499</span></li>
                        <li class="list-group-item"><strong>Storage:</strong> <span id="mobileStorage">128GB</span></li>
                        <li class="list-group-item"><strong>Camera:</strong> <span id="mobileCamera">48MP</span></li>
                        <li class="list-group-item"><strong>Battery:</strong> <span id="mobileBattery">5000mAh</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Add Bootstrap 5 CSS and JS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

<script src="/js/apiService.js"></script>
<script>
    // Get the mobile name from the URL
    const mobileName = window.location.pathname.split('/').pop();

    // Constant images
    const constantImages = [
        'https://m.media-amazon.com/images/I/41B0VwNxFJL.jpg',
        'https://m.media-amazon.com/images/I/21rFLTV3tML.jpg'
    ];

    // Fetch mobile details
    const loadMobileDetails = async () => {
        try {
            const mobile = await apiService.get(`Purchase/${mobileName}`);

            document.getElementById('mobileBrand').textContent = mobile.brand || `${mobileName}`;
            document.getElementById('mobilePrice').textContent = mobile.price ? ` ₹${mobile.price}` : "N/A";


            const carouselInner = document.getElementById('carouselInner');
            const carouselIndicators = document.getElementById('carouselIndicators');
            carouselInner.innerHTML = '';
            carouselIndicators.innerHTML = '';

            // Slide 1 - Main Mobile Image
            const slide1 = document.createElement('div');
            slide1.classList.add('carousel-item', 'active');
            slide1.innerHTML = `<img src="${mobile.mobileImage}" class="d-block w-100 h-auto" alt="${mobile.mobileName}">`;
            carouselInner.appendChild(slide1);

            // Additional Slides
            constantImages.forEach((imgSrc, index) => {
                const slide = document.createElement('div');
                slide.classList.add('carousel-item');
                slide.innerHTML = `<img src="${imgSrc}" class="d-block w-100 h-auto" alt="Slide ${index + 2}">`;
                carouselInner.appendChild(slide);
            });

            // Create Indicators
            for (let i = 0; i < 3; i++) {
                const indicator = document.createElement('button');
                indicator.type = 'button';
                indicator.setAttribute('data-bs-target', '#mobileSlideshow');
                indicator.setAttribute('data-bs-slide-to', i.toString());
                if (i === 0) indicator.classList.add('active');
                indicator.setAttribute('aria-label', `Slide ${i + 1}`);
                carouselIndicators.appendChild(indicator);
            }

        } catch (error) {
            console.error('Error loading mobile details:', error);
        }
    };

    // Check if user is logged in
    const isUserLoggedIn = () => localStorage.getItem('username') !== null;

    // Buy Now Button Logic
    function buynowbtn(mobileName) {
        if (isUserLoggedIn()) {
            window.location.href = `/Purchase/Buy/${mobileName}`;
        } else {
            window.location.href = '/login';
        }
    }

    document.getElementById('buyNowBtn').addEventListener('click', () => buynowbtn(mobileName));

    document.addEventListener('DOMContentLoaded', loadMobileDetails);
</script>
